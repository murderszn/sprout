# Copy this file to .env for local development (dotenv loads it automatically).
#
# Pollinations secret key — optional if you use `sprout login` (BYOP).
# Resolution order at runtime: SPROUT_API_KEY env var -> ~/.sprout/config.json -> sprout login / prompt.
# SPROUT_API_KEY=sk_your_key_here

# Publishable BYOP App Key (pk_...) — attributes user sign-ins for developer earnings.
# Shipped by default in sprout-install; override here for local dev / a different app key.
# POLLINATIONS_BYOP_KEY=pk_your_app_key
#
# GitHub Pages OAuth redirect (register exactly one in enter.pollinations.ai → App Key):
#   https://murderszn.github.io/sprout/callback
# Alternate path also supported: https://murderszn.github.io/sprout/login

# Optional: override the default model (default: gpt-5.4-mini)
# SPROUT_MODEL=gpt-5.4
