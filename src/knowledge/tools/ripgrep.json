{
  "name": "rg",
  "displayName": "ripgrep",
  "aliases": ["ripgrep"],
  "description": "Fast recursive grep. Note the package name (ripgrep) differs from the binary name (rg).",
  "verify": { "command": ["rg", "--version"], "expectedPattern": "ripgrep \\d+" },
  "platforms": {
    "darwin": {
      "preferredManager": "brew",
      "installs": [
        { "manager": "brew", "command": ["brew", "install", "ripgrep"], "requiresSudo": false }
      ]
    },
    "linux": {
      "preferredManager": "apt-get",
      "installs": [
        { "manager": "apt-get", "command": ["sudo", "apt-get", "install", "-y", "ripgrep"], "requiresSudo": true },
        { "manager": "dnf", "command": ["sudo", "dnf", "install", "-y", "ripgrep"], "requiresSudo": true },
        { "manager": "cargo", "command": ["cargo", "install", "ripgrep"], "requiresSudo": false, "notes": "Builds from source; ~/.cargo/bin must be on PATH." }
      ]
    },
    "win32": {
      "preferredManager": "winget",
      "installs": [
        { "manager": "winget", "command": ["winget", "install", "--id", "BurntSushi.ripgrep.MSVC", "--accept-source-agreements", "--accept-package-agreements"], "requiresSudo": false },
        { "manager": "choco", "command": ["choco", "install", "ripgrep", "-y"], "requiresSudo": false },
        { "manager": "scoop", "command": ["scoop", "install", "ripgrep"], "requiresSudo": false }
      ]
    }
  },
  "commonFailures": [
    "Users try `apt-get install rg` / `brew install rg` and fail — the package is `ripgrep`, the binary is `rg`."
  ]
}
